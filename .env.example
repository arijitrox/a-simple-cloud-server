# Copy this to .env and fill in real values. Never commit .env.

# Cloudflare Tunnel — get token from dash.cloudflare.com > Zero Trust > Tunnels
CF_TUNNEL_TOKEN=

# MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=

# Postgres
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=warehouse

# Open-WebUI Pipelines API key
PIPELINES_API_KEY=

# Gitea runner — get from Gitea Admin > Runners
GITEA_RUNNER_REGISTRATION_TOKEN=

# Jupyter Lab
JUPYTER_TOKEN=

# Restic backup encryption password — keep safe, cannot restore without it
RESTIC_PASSWORD=

# OpenClaw gateway auth token — generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# auto_ingestor.py — MinIO connection from client machines
MINIO_URL=http://<server-ip>:9000
MINIO_BUCKET=lab-logs
