import os
import socket
import time
import multiprocessing
import random

# --- ATTEMPT TO LOAD THE GPU ENGINE ---
try:
    import torch
    HAS_GPU_SUPPORT = True
except ImportError:
    HAS_GPU_SUPPORT = False

# --- CONFIGURATION ---
TOTAL_SAMPLES = 100_000_000  # 100 Million points
BATCH_SIZE = 10_000_000      # Batch size for GPU to avoid OOM

def monte_carlo_pi_part(n):
    """
    CPU: Calculates a fraction of Pi using random sampling.
    """
    count = 0
    for _ in range(n):
        x = random.random()
        y = random.random()
        if x*x + y*y <= 1:
            count += 1
    return count

def calculate_pi_gpu(total_samples):
    """
    GPU: Calculates Pi using PyTorch tensors on AMD ROCm / Nvidia CUDA.
    """
    if not torch.cuda.is_available():
        print("❌ No GPU detected by PyTorch. Falling back to CPU.")
        return calculate_pi_cpu(total_samples)

    # Get the first GPU (Navi 2 or 7900 XTX)
    device = torch.device("cuda")
    name = torch.cuda.get_device_name(0)
    
    print(f"\n" + "="*40)
    print(f"🦖 GPU ENGINE ENGAGED: {name}")
    print(f"🚀 Job: Calculate Pi using {total_samples:,} samples")
    print("="*40 + "\n")

    start_time = time.time()
    
    # Process in batches to manage VRAM usage
    total_inside = 0
    samples_processed = 0
    
    print(f"⚡ Firing Tensor Cores...")
    
    # Simple loop for batches (can also use just one big tensor if VRAM permits)
    # 100M floats = ~800MB VRAM, so we can actually do it in one shot on 24GB cards.
    # But batching is safer for generic scripts.
    while samples_processed < total_samples:
        current_batch = min(BATCH_SIZE, total_samples - samples_processed)
        
        # Generate random points (x, y) directly on GPU VRAM
        x = torch.rand(current_batch, device=device)
        y = torch.rand(current_batch, device=device)
        
        # Calculate distance from origin (x^2 + y^2 <= 1)
        # This operation happens on thousands of cores simultaneously
        inside = (x**2 + y**2 <= 1).sum().item()
        
        total_inside += inside
        samples_processed += current_batch

    pi_estimate = (total_inside * 4) / total_samples
    
    end_time = time.time()
    duration = end_time - start_time
    
    return pi_estimate, duration

def calculate_pi_cpu(total_samples):
    """
    CPU: Distributed Multiprocessing Version
    """
    host = socket.gethostname()
    cores = multiprocessing.cpu_count()
    
    print(f"\n" + "="*40)
    print(f"🏭 PROCESSING NODE: {host}")
    print(f"🧠 CPU CORES ENGAGED: {cores}")
    print(f"🚀 Job: Calculate Pi using {total_samples:,} samples")
    print("="*40 + "\n")

    pool = multiprocessing.Pool(processes=cores)
    samples_per_core = total_samples // cores
    
    start_time = time.time()
    
    print(f"⚡ Spawning {cores} worker processes...")
    results = pool.map(monte_carlo_pi_part, [samples_per_core] * cores)
    
    pool.close()
    pool.join()

    total_inside = sum(results)
    pi_estimate = (total_inside * 4) / total_samples
    
    end_time = time.time()
    duration = end_time - start_time
    
    return pi_estimate, duration

if __name__ == "__main__":
    # AUTO-DETECT: Prefer GPU if PyTorch is installed and GPU is found
    if HAS_GPU_SUPPORT and torch.cuda.is_available():
        pi, duration = calculate_pi_gpu(TOTAL_SAMPLES)
        mode = "GPU (ROCm/CUDA)"
    else:
        if HAS_GPU_SUPPORT and not torch.cuda.is_available():
            print("⚠️  PyTorch installed but GPU not found. Using CPU.")
        elif not HAS_GPU_SUPPORT:
            print("⚠️  PyTorch not installed. Using CPU.")
        
        pi, duration = calculate_pi_cpu(TOTAL_SAMPLES)
        mode = "CPU (Multiprocessing)"

    # Report
    print(f"✅ CALCULATION COMPLETE ({mode})")
    print(f"π Estimate: {pi}")
    print(f"⏱️ Time taken: {duration:.4f} seconds")
    print(f"🔥 Throughput: {TOTAL_SAMPLES / duration:,.0f} samples/sec")